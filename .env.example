# Copy this file to .env and fill in your CoinGecko demo API key.
#   cp .env.example .env

# Required — CoinGecko Demo API key (https://www.coingecko.com/en/developers/dashboard)
COINGECKO_API_KEY=CG-your-demo-key-here

# Optional overrides (defaults shown)
# PORT=8080
# ALLOWED_ORIGIN=http://localhost:5173
# COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
